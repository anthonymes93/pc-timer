{
  "name": "pc-timer",
  "version": "1.0.0",
  "description": "20 minute PC timer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^38.0.0",
    "electron-builder": "^26.0.12"
  },
"build": {
  "appId": "com.anthony.pctimer",
  "productName": "PC Timer",

  "publish": [
    {
      "provider": "github",
      "owner": "anthonymes93",
      "repo": "pc-timer"
    }
  ],

  "win": {
    "target": "nsis"
  },

  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
},
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
